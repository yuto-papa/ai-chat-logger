{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Server (Debug)",
      "type": "shell",
      "command": "npm run dev:debug",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "vite",
          "endsPattern": "ready in|Local:"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "debug"
      }
    }
  ]
}
