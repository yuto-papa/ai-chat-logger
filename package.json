{
  "name": "thinking-tool",
  "version": "1.0.0",
  "description": "Claude CLI session manager with xterm.js",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:debug": "cross-env VSCODE_DEBUG=true vite",
    "build": "vite build",
    "preview": "vite preview",
    "rebuild-pty": "electron-rebuild -f -w node-pty",
    "postinstall": "node scripts/postinstall.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ui": "npm run build && playwright test --ui"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "reactflow": "^11.11.4",
    "uuid": "^13.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^6.0.2",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.1"
  },
  "build": {
    "appId": "com.thinkingtool.app",
    "productName": "ThinkingTool",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
